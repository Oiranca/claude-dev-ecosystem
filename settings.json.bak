{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CAVEMAN_DEFAULT_MODE": "ultra",
    "LINEAR_API_KEY": "${LINEAR_API_KEY}"
  },
  "model": "haiku",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/pre-edit-check.sh \"$CLAUDE_TOOL_INPUT_FILE_PATH\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/caveman-init.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf 'CAVEMAN ULTRA ACTIVE. Never revert. Drop articles/filler/pleasantries. Fragments OK. Technical terms exact.'",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "rm -rf /tmp/playwright-mcp 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "caveman@caveman": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "general": {
    "enableNotifications": true
  },
  "experimental": {
    "enableAgents": true,
    "worktrees": true
  },
  "ui": {
    "footer": {
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "quota",
        "token-count",
        "statusline"
      ]
    }
  },
  "hooksConfig": {
    "enabled": true,
    "notifications": true
  }
}
